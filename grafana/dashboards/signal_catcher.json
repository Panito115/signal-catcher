          "refId": "Conversions"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "options": { "xField": "state" },
      "title": "Top 10 States by Impressions",
      "type": "barchart",
      "targets": [
        {
          "query": "from(bucket: \"signal_catcher\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"ad_events\" and r.event_type == \"impression\" and r._field == \"count\")\n  |> group(columns: [\"state\"])\n  |> sum()\n  |> sort(columns: [\"_value\"], desc: true)\n  |> limit(n: 10)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "options": { "xField": "advertiser_id" },
