        },
        {
          "query": "from(bucket: \"signal_catcher\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"ad_events\" and r._field == \"count\" and r.event_type == \"click\")\n  |> aggregateWindow(every: 1m, fn: sum, createEmpty: false)",
