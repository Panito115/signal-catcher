      "title": "Total Impressions",
      "type": "stat",
      "targets": [
        {
          "query": "from(bucket: \"signal_catcher\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"ad_events\" and r.event_type == \"impression\" and r._field == \"count\")\n  |> sum()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
